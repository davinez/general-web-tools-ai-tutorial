@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @(currentCount)</p>

<!-- Conditionally render -->
@if (currentCount > 20)
{
    <p>You win!</p>
}


<!-- You can specify C# event handlers for other
HTML events too, like @onchange, @oninput, and so on.
Event handling methods can be synchronous or asynchronous.
You can also define event handlers inline using C# lambda expressions: -->
<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    [Parameter]
    public int IncrementAmount { get; set; } = 1;

    private void IncrementCount()
    {
        currentCount += IncrementAmount;
    }
}
